# Salin ke .env lalu SESUAIKAN. Jangan `cp` menimpa .env yang sudah jalan!
#
# DATABASE_URL — pilih salah satu:
#   Postgres lokal (macOS/Homebrew): pakai username sistemmu, mis. `whoami`
#     postgresql+psycopg2://<user-mu>@localhost:5432/nusabahasa
#   Docker compose (service `db`):
#     postgresql+psycopg2://nusa:nusa@db:5432/nusabahasa
DATABASE_URL=postgresql+psycopg2://postgres@localhost:5432/nusabahasa

JWT_SECRET=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Vite bisa lompat port bila 5173/5174 terpakai — daftarkan cadangannya
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175

# --- Cloudflare R2 (dipakai /audio/* & /ai/*) — jangan di-commit ---
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=nusabahasa
